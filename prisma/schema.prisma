generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPERADMIN
  ADMIN
  CONSULTANT
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DomainStatus {
  PENDING
  ACTIVE
  ERROR
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String
  role             UserRole  @default(CONSULTANT)
  image            String?
  resetToken       String?   @map("reset_token")
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  consultant       Consultant?

  @@map("users")
}

model Consultant {
  id           String  @id @default(cuid())
  userId       String  @unique @map("user_id")
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Dati Personali
  firstName    String  @map("first_name")
  lastName     String  @map("last_name")
  title        String? // "Dott.", "Ing.", etc.
  role         String  // "Executive Manager", "Financial Advisor", etc.
  network      String? // "Rete Private e Wealth", etc.
  bio          String? @db.Text
  profileImage String? @map("profile_image")
  themeColor   String? @map("theme_color")

  // Contatti
  email    String
  phone    String?
  mobile   String?
  address  String?
  cap      String?
  city     String?
  province String?

  // Certificazioni
  efpa               Boolean @default(false)
  efpaEsg            Boolean @default(false) @map("efpa_esg")
  sustainableAdvisor Boolean @default(false) @map("sustainable_advisor")

  // Social
  linkedinUrl  String? @map("linkedin_url")
  facebookUrl  String? @map("facebook_url")
  twitterUrl   String? @map("twitter_url")
  instagramUrl String? @map("instagram_url")
  tiktokUrl    String? @map("tiktok_url")
  youtubeUrl   String? @map("youtube_url")
  websiteUrl   String? @map("website_url")

  // Relazioni
  landingPage LandingPage?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("consultants")
}

model LandingPage {
  id           String     @id @default(cuid())
  consultantId String     @unique @map("consultant_id")
  consultant   Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  slug         String     @unique
  status       PageStatus @default(DRAFT)

  // Sezioni (JSON per flessibilità)
  coverData          Json? @map("cover_data")
  summaryData        Json? @map("summary_data")
  mapData            Json? @map("map_data")
  skillsData         Json? @map("skills_data")
  experiencesData    Json? @map("experiences_data")
  educationData      Json? @map("education_data")
  interestsData      Json? @map("interests_data")
  bannerData         Json? @map("banner_data")
  focusOnData        Json? @map("focus_on_data")
  testimonialsData   Json? @map("testimonials_data")
  videoData          Json? @map("video_data")
  portfolioData      Json? @map("portfolio_data")
  quoteData          Json? @map("quote_data")
  valuesData         Json? @map("values_data")
  processData        Json? @map("process_data")
  methodData         Json? @map("method_data")
  strengthsData      Json? @map("strengths_data")
  faqData            Json? @map("faq_data")

  // SEO
  metaTitle       String? @map("meta_title")
  metaDescription String? @db.Text @map("meta_description")

  // Dominio
  customDomain CustomDomain?

  // SEO & Analytics
  ga4MeasurementId   String?   @map("ga4_measurement_id")
  gscVerificationTag String?   @map("gsc_verification_tag")
  pagespeedMobile    Int?      @map("pagespeed_mobile")
  pagespeedDesktop   Int?      @map("pagespeed_desktop")
  pagespeedCheckedAt DateTime? @map("pagespeed_checked_at")

  // Analytics
  views        Int       @default(0)
  lastViewedAt DateTime? @map("last_viewed_at")

  // Relazioni
  contactSubmissions ContactSubmission[]
  pageViews          PageView[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("landing_pages")
}

model CustomDomain {
  id              String       @id @default(cuid())
  landingPageId   String       @unique @map("landing_page_id")
  landingPage     LandingPage  @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  domain          String       @unique
  status          DomainStatus @default(PENDING)
  sslStatus       String?      @map("ssl_status")
  verificationTxt String?      @map("verification_txt")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@map("custom_domains")
}

model ContactSubmission {
  id              String      @id @default(cuid())
  landingPageId   String      @map("landing_page_id")
  landingPage     LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  firstName       String      @map("first_name")
  lastName        String      @map("last_name")
  email           String
  phone           String?
  message         String?     @db.Text
  isExistingClient Boolean    @default(false) @map("is_existing_client")
  isRead          Boolean     @default(false) @map("is_read")
  readAt          DateTime?   @map("read_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  @@index([landingPageId])
  @@map("contact_submissions")
}

model PageView {
  id            String      @id @default(cuid())
  landingPageId String      @map("landing_page_id")
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  date          DateTime    @db.Date
  views         Int         @default(0)

  @@unique([landingPageId, date])
  @@index([landingPageId])
  @@index([date])
  @@map("page_views")
}

model Media {
  id         String   @id @default(cuid())
  filename   String
  url        String
  mimeType   String   @map("mime_type")
  size       Int
  uploadedBy String   @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("media")
}

model InvitationToken {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique
  role        String    @default("CONSULTANT")
  network     String?
  createdById String    @map("created_by_id")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("invitation_tokens")
}
